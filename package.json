{
  "name": "nodejs-practice",
  "version": "1.0.0",
  "description": "testing",
  "main": "main.js",
  "scripts": {
    "start": "node src/main.js",
    "test": "jest",
    "db:init": "node src/scripts/init-db.js",
    "db:reset": "del /Q data/app.sqlite 2>nul & && npm run db:init"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phohlova/nodejs-practice.git"
  },
  "keywords": [
    "-"
  ],
  "author": "polina",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/phohlova/nodejs-practice/issues"
  },
  "homepage": "https://github.com/phohlova/nodejs-practice#readme",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "./jest.setup.js"
    ],
    "coverageDirectory": "./coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "verbose": true
  },
  "dependencies": {
    "axios": "^1.16.1",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
  }
}
